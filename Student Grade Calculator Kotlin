/**
 * Logique de calcul du Grade (Note).
 */
fun getGrade(score: Int): Char = when (score) {
    in 90..100 -> 'A'
    in 80..89 -> 'B'
    in 70..79 -> 'C'
    in 60..69 -> 'D'
    else -> 'F'
}

/**
 * Formate le message de résultat d'un étudiant pour le partage.
 */
fun formatStudentGrade(student: Student): String {
    return student.score?.let {
        "${student.name} marqué $it : Grade ${getGrade(it)}"
    } ?: "Pas de score pour ${student.name}"
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun GradeCalculatorApp(onBack: () -> Unit) {
    val context = LocalContext.current
    val students = remember {
        mutableStateListOf(
            Student(1, "Alice", 95),
            Student(2, "Bob", 82),
            Student(3, "Charlie", null),
            Student(4, "Diana", 47)
        )
    }

    var showAddDialog by remember { mutableStateOf(false) }

    val filePickerLauncher = rememberLauncherForActivityResult(
        contract = ActivityResultContracts.GetContent()
    ) { uri: Uri? ->
        uri?.let {
            try {
                val inputStream = context.contentResolver.openInputStream(it)
                val reader = BufferedReader(InputStreamReader(inputStream))
                val newEntries = reader.lineSequence().mapIndexedNotNull { index, line ->
                    val parts = line.split(",")
                    if (parts.isNotEmpty()) {
                        val name = parts[0].trim()
                        val score = parts.getOrNull(1)?.trim()?.toIntOrNull()
                        if (name.isNotEmpty()) {
                            Student(System.currentTimeMillis() + index, name, score)
                        } else null
                    } else null
                }.toList()
                
                if (newEntries.isNotEmpty()) {
                    students.addAll(newEntries)
                    Toast.makeText(context, "${newEntries.size} étudiants importés", Toast.LENGTH_SHORT).show()
                }
            } catch (e: Exception) {
                Toast.makeText(context, "Erreur lors de l'importation", Toast.LENGTH_SHORT).show()
            }
        }
    }

    fun shareText(text: String) {
        val intent = Intent(Intent.ACTION_SEND).apply {
            type = "text/plain"
            putExtra(Intent.EXTRA_TEXT, text)
        }
        context.startActivity(Intent.createChooser(intent, "Partager via"))
    }

    Scaffold(
        topBar = {
            TopAppBar(
                title = { Text("Calculateur", fontWeight = FontWeight.Bold) },
                navigationIcon = {
                    IconButton(onClick = onBack) {
                        Icon(Icons.AutoMirrored.Filled.ArrowBack, contentDescription = "Retour")
                    }
                },
                actions = {
                    IconButton(onClick = { filePickerLauncher.launch("text/*") }) {
                        Icon(Icons.Default.Add, contentDescription = "Importer")
                    }
                    IconButton(onClick = {
                        val shareContent = "📊 Rapport global des Grades :\n\n" + 
                            students.joinToString("\n") { formatStudentGrade(it) }
                        shareText(shareContent)
                    }) {
                        Icon(Icons.AutoMirrored.Filled.Send, contentDescription = "Tout partager")
                    }
                },
                colors = TopAppBarDefaults.topAppBarColors(
                    containerColor = MaterialTheme.colorScheme.surface,
                    titleContentColor = MaterialTheme.colorScheme.primary
                )
            )
        },
        floatingActionButton = {
            FloatingActionButton(
                onClick = { showAddDialog = true },
                containerColor = MaterialTheme.colorScheme.primaryContainer,
                contentColor = MaterialTheme.colorScheme.onPrimaryContainer
            ) {
                Icon(Icons.Default.Add, contentDescription = "Ajouter un étudiant")
            }
        }
    ) { innerPadding ->
        Box(modifier = Modifier.padding(innerPadding)) {
            if (students.isEmpty()) {
                Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                    Text("Aucun étudiant. Ajoutez-en un !", color = MaterialTheme.colorScheme.outline)
                }
            } else {
                LazyColumn(
                    modifier = Modifier.fillMaxSize(),
                    contentPadding = PaddingValues(16.dp),
                    verticalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    items(students, key = { it.id }) { student ->
                        StudentCard(
                            student = student,
                            onDelete = { students.remove(student) },
                            onShare = { shareText(formatStudentGrade(student)) }
                        )
                    }
                }
            }
        }

        if (showAddDialog) {
            AddStudentDialog(
                onDismiss = { showAddDialog = false },
                onAdd = { name, score ->
                    students.add(Student(System.currentTimeMillis(), name, score))
                    showAddDialog = false
                }
            )
        }
    }
}

@Composable
fun AddStudentDialog(onDismiss: () -> Unit, onAdd: (String, Int?) -> Unit) {
    var name by remember { mutableStateOf("") }
    var scoreStr by remember { mutableStateOf("") }

    AlertDialog(
        onDismissRequest = onDismiss,
        title = { Text("Nouvel Étudiant") },
        text = {
            Column {
                OutlinedTextField(
                    value = name,
                    onValueChange = { name = it },
                    label = { Text("Nom") },
                    singleLine = true,
                    modifier = Modifier.fillMaxWidth()
                )
                Spacer(modifier = Modifier.height(8.dp))
                OutlinedTextField(
                    value = scoreStr,
                    onValueChange = { scoreStr = it },
                    label = { Text("Score (facultatif)") },
                    singleLine = true,
                    keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Number),
                    modifier = Modifier.fillMaxWidth()
                )
            }
        },
        confirmButton = {
            Button(
                onClick = { if (name.isNotBlank()) onAdd(name, scoreStr.toIntOrNull()) },
                enabled = name.isNotBlank()
            ) {
                Text("Ajouter")
            }
        },
        dismissButton = {
            TextButton(onClick = onDismiss) {
                Text("Annuler")
            }
        }
    )
}

@Composable
fun StudentCard(student: Student, onDelete: () -> Unit, onShare: () -> Unit) {
    Card(
        modifier = Modifier.fillMaxWidth(),
        shape = MaterialTheme.shapes.extraLarge,
        colors = CardDefaults.cardColors(
            containerColor = MaterialTheme.colorScheme.surfaceColorAtElevation(4.dp)
        )
    ) {
        Row(
            modifier = Modifier.padding(20.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    text = student.name,
                    style = MaterialTheme.typography.titleLarge,
                    fontWeight = FontWeight.Bold
                )
                val statusText = student.score?.let {
                    "Score : $it • Grade : ${getGrade(it)}"
                } ?: "Pas de score pour ${student.name}"
                
                Text(
                    text = statusText,
                    style = MaterialTheme.typography.bodyMedium,
                    color = if (student.score == null) MaterialTheme.colorScheme.error else MaterialTheme.colorScheme.primary
                )
            }
            Row {
                IconButton(onClick = onShare) {
                    Icon(
                        Icons.Default.Share,
                        contentDescription = "Partager ce score",
                        tint = MaterialTheme.colorScheme.primary
                    )
                }
                IconButton(onClick = onDelete) {
                    Icon(
                        Icons.Default.Delete,
                        contentDescription = "Supprimer",
                        tint = MaterialTheme.colorScheme.error
                    )
                }
            }
        }
    }
}
